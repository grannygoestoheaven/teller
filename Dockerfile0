# === STAGE 1: Build ===
# Use a full image for building dependencies (e.g., Python + Node.js)
FROM python:3.11 as builder
# Install system dependencies (as root)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    wget \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*  # Clean up to reduce image size

WORKDIR /app

COPY . .

# Install Python dependencies (as appuser)
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements-minimal.txt

COPY teller_vite/package* ./teller_vite/  # Copy package.json and package-lock.json

WORKDIR /app/teller_vite

# Install nodejs dependencies
RUN npm ci --omit=dev

COPY teller_vite .

RUN npm run build:build-vite

# === STAGE 2: Runtime ===
# Use a slim image for the final runtime
FROM python:3.11-slim

# Create and switch to a non-root user for security - /app at the end means the permissions are applied on the /app directory
RUN useradd -m appuser && chown -R appuser:usergroup /app

USER appuser

WORKDIR /app

# Copy only the built frontend and Python dependencies from the builder
COPY --from=builder app/home/.local /app/home/.local  # Python deps
COPY --from=builder app/teller_vite/dist /app/teller_vite/dist  # Frontend assets
COPY --from=builder app/main.py ./main.py  # App code

# Expose the port and run the app (here EXPOSE is just for documentation, it doesn't actually publish the port)
EXPOSE 8080

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
